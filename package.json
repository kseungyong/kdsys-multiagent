{
  "name": "kdsys-multiagent",
  "version": "1.0.0",
  "description": "KDSys MultiAgent Lab - Multi-AI chat room",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop kdsys-multiagent",
    "pm2:restart": "pm2 restart kdsys-multiagent",
    "pm2:logs": "pm2 logs kdsys-multiagent",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "RUN_INTEGRATION=true jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^6.33.0",
    "pdf-parse-new": "^2.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
